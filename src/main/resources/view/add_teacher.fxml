<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" style="-fx-padding: 40;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.schooldiary.controller.MainController">
    <Label text="Регистрация нового учителя" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <GridPane vgap="15" hgap="15" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="100"/>
            <ColumnConstraints halignment="LEFT" minWidth="300"/>
        </columnConstraints>

        <Label text="ФИО:" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" promptText="Введите полное имя" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Предмет:" GridPane.rowIndex="1"/>
        <TextField fx:id="subjectField" promptText="Напр. Математика" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Email/Логин:" GridPane.rowIndex="2"/>
        <TextField fx:id="loginField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Пароль:" GridPane.rowIndex="3"/>
        <PasswordField fx:id="passwordField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Button text="Создать аккаунт" onAction="#processAddTeacher"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"
                GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>
</VBox>