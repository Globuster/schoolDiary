<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" style="-fx-padding: 50;">

    <Circle radius="50" fill="#bdc3c7" />
    <Label fx:id="profileName" text="Имя Пользователя" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label fx:id="profileRole" text="Роль: Ученик" style="-fx-text-fill: #7f8c8d;"/>

    <Separator maxWidth="300"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Редактировать данные" />
        <Button text="Сменить пароль" />
    </HBox>
</VBox>