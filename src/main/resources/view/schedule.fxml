<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" style="-fx-padding: 20;" >

    <Label text="Расписание занятий" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Понедельник">
            <ListView fx:id="mondayList" />
        </Tab>
        <Tab text="Вторник">
            <ListView fx:id="tuesdayList" />
        </Tab>
        <Tab text="Среда">
            <ListView fx:id="wednesdayList" />
        </Tab>
        <Tab text="Четверг">
            <ListView fx:id="thursdayList" />
        </Tab>
        <Tab text="Пятница">
            <ListView fx:id="fridayList" />
        </Tab>
    </TabPane>
</VBox>