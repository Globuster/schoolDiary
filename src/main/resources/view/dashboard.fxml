<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox spacing="20" style="-fx-padding: 30;">
        <Label text="Панель управления" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <FlowPane hgap="20" vgap="20">
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                <Label text="Последние оценки" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                <Label text="Математика: 5" />
                <Label text="История: 4" />
                <Button text="Смотреть все" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-padding: 5 0 0 0;"/>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                <Label text="Следующий урок" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                <Label text="14:00 - География" style="-fx-font-size: 18px; -fx-text-fill: #e67e22;"/>
                <Label text="Кабинет: 302" />
            </VBox>
        </FlowPane>
    </VBox>
</ScrollPane>