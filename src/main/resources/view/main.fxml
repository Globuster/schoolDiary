<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.schooldiary.controller.MainController">

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Label fx:id="userLabel"/>
            <Button text="Выход" onAction="#handleLogout"/>
        </HBox>
    </top>

    <left>
        <VBox fx:id="menuBox" spacing="5">
            <Button fx:id="dashboardBtn" text="Главная"/>
            <Button fx:id="gradesBtn" text="Оценки"/>
            <Button fx:id="usersBtn" text="Пользователи"/>
        </VBox>
    </left>

    <center>
        <Label text="Добро пожаловать!"/>
    </center>

</BorderPane>