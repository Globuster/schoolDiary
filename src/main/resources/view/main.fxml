<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane stylesheets="@style.css" prefHeight="800.0" prefWidth="1200.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.schooldiary.controller.MainController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT" spacing="20">
            <padding>
                <Insets left="20" right="20" top="10" bottom="10"/>
            </padding>
            <Text styleClass="logo-text" text="SCHOOL | Diary" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="15">
                <Label fx:id="userLabel" styleClass="user-name" text="Загрузка..." />
                <Button onAction="#handleLogout" styleClass="btn-logout" text="Выход" />
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox fx:id="menuBox" styleClass="sidebar" spacing="8" prefWidth="260">
            <padding>
                <Insets top="20" left="10" right="10"/>
            </padding>

            <Label text="ОСНОВНОЕ" styleClass="menu-section-label"/>
            <Button fx:id="dashboardBtn" text="🏠 Главная" onAction="#showDashboard" styleClass="menu-button" maxWidth="Infinity"/>
            <Button fx:id="gradesBtn" text="📊 Оценки" onAction="#showGrades" styleClass="menu-button" maxWidth="Infinity"/>
            <Button fx:id="Schedule" text="📅 Расписание" onAction="#showSchedule" styleClass="menu-button" maxWidth="Infinity"/>
            <Button fx:id="Homeworks" text="📚 Домашние задания" onAction="#showHomeworks" styleClass="menu-button" maxWidth="Infinity"/>

            <Separator styleClass="menu-separator"/>

            <Label text="УПРАВЛЕНИЕ" styleClass="menu-section-label"/>
            <Button fx:id="Teachers" text="👨‍🏫 Учителя" onAction="#showTeachers" styleClass="menu-button" maxWidth="Infinity"/>
            <Button fx:id="Students" text="🎓 Ученики" onAction="#showStudents" styleClass="menu-button" maxWidth="Infinity"/>

            <Button fx:id="AddTeacher" text="➕ Добавить учителя" onAction="#showAddTeacherForm" styleClass="menu-button" maxWidth="Infinity" />
            <Button fx:id="AddClass" text="🏫 Добавить класс" onAction="#showAddClassForm" styleClass="menu-button" maxWidth="Infinity" />

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="ProfileBtn" text="👤 Мой профиль" onAction="#showProfile" styleClass="menu-button-alt" maxWidth="Infinity">
                <VBox.margin>
                    <Insets bottom="20" />
                </VBox.margin>
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="main-content">
            <VBox alignment="CENTER" spacing="15">
                <Label text="Добро пожаловать!" styleClass="welcome-title" />
                <Label text="Выберите интересующий раздел в меню слева" styleClass="welcome-subtitle" />
            </VBox>
        </StackPane>
    </center>

</BorderPane>